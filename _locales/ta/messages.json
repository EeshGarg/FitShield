  "welcomeThemeTitle": {
    "message": "ஒரு தீம் தேர்வுசெய்க"
  },
  "welcomeThemeBody": {
    "message": "நிறங்களை பின்னர் அமைப்புகளில் சரிசெய்யலாம்."
  },
  "welcomeFastFoodTitle": {
    "message": "துரித உணவு ஆர்டரைத் தடு"
  },
  "welcomeFastFoodBody": {
    "message": "பெரிய துரித உணவு சங்கிலிகளின் ஆர்டர் பக்கங்களில் ஒரு இடைநிறுத்தத் திரையைச் சேர்க்கிறது."
  },
  "welcomeRecommendedOn": {
    "message": "இயக்கம் பரிந்துரைக்கப்படுகிறது."
  },
  "welcomeDeliveryTitle": {
    "message": "டெலிவரி ஆப்களைத் தடு"
  },
  "welcomeDeliveryBody": {
    "message": "DoorDash மற்றும் Uber Eats போன்ற டெலிவரி தளங்களில் ஒரு இடைநிறுத்தத் திரையைச் சேர்க்கிறது."
  },
  "welcomeImportTitle": {
    "message": "காப்புப்பிரதியை மீட்டெடு (விருப்பத்திற்குரியது)"
  },
  "welcomeImportBody": {
    "message": "வேறு சாதனத்திலிருந்து வருகிறீர்களா? எல்லாவற்றையும் கொண்டுவர FitShield அமைப்புக் கோப்பை இறக்குமதி செய்யுங்கள். இல்லையெனில் தொடருங்கள்."
  },
  "welcomeImportButton": {
    "message": "அமைப்புக் கோப்பை இறக்குமதி செய்"
  },
  "welcomeHelpTitle": {
    "message": "FitShield எப்படி உதவுகிறது"
  },
  "welcomeHelpBody": {
    "message": "முக்கிய அம்சங்களின் விரைவுச் சுற்று."
  },
  "welcomeFeaturePauseTitle": {
    "message": "இடைநிறுத்த டைமர்"
  },
  "welcomeFeaturePauseBody": {
    "message": "தடுக்கப்பட்ட தளத்தை அடைந்தால், தொடர்வதற்கு முன் ஒரு குறுகிய எண்ணிக்கை இயங்கும் — ஆர்டரை மறுபரிசீலனை செய்ய போதுமானது."
  },
  "welcomeFeatureScheduleTitle": {
    "message": "அட்டவணை"
  },
  "welcomeFeatureScheduleBody": {
    "message": "விரும்பினால் மாலை அல்லது வேலை நேரம் போன்ற குறிப்பிட்ட நேரங்களில் மட்டும் தடுக்கவும்."
  },
  "welcomeFeatureWhitelistTitle": {
    "message": "வெள்ளைப் பட்டியல்"
  },
  "welcomeFeatureWhitelistBody": {
    "message": "எந்தத் தளத்தையும் அணைக்கவும், உங்கள் URL-களைச் சேர்க்கவும், அல்லது உண்மையில் தேவைப்படும்போது தற்காலிக அனுமதி அளிக்கவும்."
